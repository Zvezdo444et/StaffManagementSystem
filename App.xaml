<Application x:Class="Inspector.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Inspector"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:Inspector.ViewModels"
             xmlns:employeesVm="clr-namespace:Inspector.ViewModels.Employees"
             xmlns:searchVm="clr-namespace:Inspector.ViewModels.Search"
             xmlns:views="clr-namespace:Inspector.Views"
             xmlns:employeesViews="clr-namespace:Inspector.Views.Employees">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign2.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Light.xaml" />
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="Green" SecondaryColor="Green" />
                <ResourceDictionary Source="Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <DataTemplate DataType="{x:Type employeesVm:PersonalDataViewModel}">
                <employeesViews:PersonalDataView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type employeesVm:QualificationViewModel}">
                <employeesViews:QualificationView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type employeesVm:AppointmentViewModel}">
                <employeesViews:AppointmentView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type employeesVm:VacationViewModel}">
                <employeesViews:VacationView />
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                <views:SettingsView />
            </DataTemplate>
            
            <DataTemplate DataType="{x:Type employeesVm:EmployeesListViewModel}">
                <employeesViews:EmployeesListView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                <views:ReportsView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:NotificationsViewModel}">
                <views:NotificationsView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:PensionAgeViewModel}">
                <views:PensionAgeView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type searchVm:SearchViewModel}">
                <views:SearchView />
            </DataTemplate>

            <DataTemplate DataType="{x:Type vm:PlaceholderViewModel}">
                <views:PlaceholderView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
