<UserControl x:Class="Inspector.Views.PensionAgeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="500"
             d:DesignWidth="800"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Title}"
                   FontSize="28"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,20" />

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
           
            <Border Grid.Column="0"
                    Background="{StaticResource PensionCardPinkBrush}"
                    CornerRadius="16"
                    Padding="20"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.12" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Пенсионный возраст для мужчин"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" />
                    <TextBlock Text="{Binding MenAgeText}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentRedBrush}"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
            
            <Border Grid.Column="2"
                    Background="{StaticResource WomenPensionCardBgBrush}"
                    CornerRadius="16"
                    Padding="20"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.12" Direction="270" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Пенсионный возраст для женщин"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" />
                    <TextBlock Text="{Binding WomenAgeText}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource WomenPensionTextBrush}"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="16"
                    Padding="20"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.12" Direction="270" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0"
                           Source="pack://application:,,,/Inspector;component/Resources/Images/icon-pension.png"
                           Width="48"
                           Height="48"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Мужчин достигших пенсионного возраста"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding MenReachedCount}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
            
            <Border Grid.Column="2"
                    Background="White"
                    CornerRadius="16"
                    Padding="20"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.12" Direction="270" />
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0"
                           Source="pack://application:,,,/Inspector;component/Resources/Images/icon-pension2.png"
                           Width="48"
                           Height="48"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Женщин достигших пенсионного возраста"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding WomenReachedCount}"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Button Grid.Row="3"
                Content="Настроить пенсионный возраст"
                Command="{Binding OpenConfigureCommand}"
                Style="{StaticResource MaterialDesignRaisedButton}"
                materialDesign:ButtonAssist.CornerRadius="16"
                Height="52"
                Padding="32,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                FontWeight="SemiBold"
                FontSize="15"
                Background="{StaticResource AccentGreenBrush}"
                Foreground="White"
                BorderBrush="{StaticResource AccentGreenDarkBrush}"
                BorderThickness="1">
            <Button.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Direction="270" />
            </Button.Effect>
        </Button>

        <Border Grid.Row="0" Grid.RowSpan="4"
                Background="#80000000"
                Visibility="{Binding IsConfigOpen, Converter={StaticResource BoolToVis}}"
                x:Name="ConfigOverlay">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="White"
                    CornerRadius="16"
                    Padding="32"
                    MinWidth="560"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.25" Direction="270" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Текущее значение для мужчин"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13"
                                       Margin="0,0,0,6" />
                            <Border Background="{StaticResource PensionCardPinkBrush}"
                                    CornerRadius="12"
                                    Padding="14,10"
                                    Margin="0,0,0,16"
                                    BorderBrush="{StaticResource BorderLightBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding MenAgeText}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentRedBrush}" />
                            </Border>
                            <TextBlock Text="Введите новое значение для мужчин"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13"
                                       Margin="0,0,0,6" />
                            <TextBox Text="{Binding ConfigMenAgeText, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Введите число"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Background="{StaticResource PensionCardPinkBrush}"
                                     Padding="12,10"
                                     FontSize="14" />
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Текущее значение для женщин"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13"
                                       Margin="0,0,0,6" />
                            <Border Background="{StaticResource WomenPensionCardBgBrush}"
                                    CornerRadius="12"
                                    Padding="14,10"
                                    Margin="0,0,0,16"
                                    BorderBrush="{StaticResource BorderLightBrush}"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding WomenAgeText}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource WomenPensionTextBrush}" />
                            </Border>
                            <TextBlock Text="Введите новое значение для женщин"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13"
                                       Margin="0,0,0,6" />
                            <TextBox Text="{Binding ConfigWomenAgeText, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Введите число"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Background="{StaticResource WomenPensionCardBgBrush}"
                                     Padding="12,10"
                                     FontSize="14" />
                        </StackPanel>
                    </Grid>
                    
                    <TextBlock Grid.Row="1"
                               Text="{Binding ConfigErrorMessage}"
                               Foreground="{StaticResource AccentRedBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"
                               HorizontalAlignment="Center" />
                    
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Сохранить и выйти"
                                Command="{Binding SaveConfigCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="12"
                                Height="44"
                                MinWidth="180"
                                Margin="0,0,12,0"
                                Background="{StaticResource AccentGreenBrush}"
                                Foreground="White"
                                FontWeight="SemiBold" />
                        <Button Content="Выйти без сохранения"
                                Command="{Binding CancelConfigCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="12"
                                Height="44"
                                MinWidth="180"
                                Background="{StaticResource AccentGreenBrush}"
                                Foreground="White"
                                FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
