<UserControl x:Class="Inspector.Views.Employees.EmployeeEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:behaviors="clr-namespace:Inspector.Behaviors"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="980">

    <UserControl.Resources>
        <Style x:Key="ScrollableTabsStyle"
               TargetType="TabControl"
               BasedOn="{StaticResource MaterialDesignTabControl}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <ScrollViewer x:Name="TabsHeaderScrollViewer"
                                          Grid.Row="0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          PreviewMouseWheel="TabsHeaderScrollViewer_OnPreviewMouseWheel">
                                <TabPanel Background="Transparent"
                                          IsItemsHost="True" />
                            </ScrollViewer>

                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"
                                              Margin="{TemplateBinding Padding}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Height="40"
                    Content="Выйти без сохранения"
                    Command="{Binding CancelCommand}"
                    Background="{StaticResource AccentGreenBrush}"
                    Foreground="White"
                    Padding="14,8"
                    BorderThickness="0"
                    Margin="0,0,12,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Style="{StaticResource MaterialDesignRaisedButton}" />

            <TextBlock Grid.Column="1"
                       Text="{Binding Title}"
                       FontSize="22"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <Border Grid.Row="1" Margin="18,0,18,18" Background="White" CornerRadius="16">
            <Grid>
                <TabControl Margin="8"
                            Style="{StaticResource ScrollableTabsStyle}">
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Данные работника">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMainSectionPartiallyFilled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentYellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMainSectionFullyFilled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </TabItem.Header>

                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Фамилия" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                             MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                             Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                                    <TextBlock Text="Имя" Margin="0,14,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                             MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                             Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                                    <TextBlock Text="Отчество" Margin="0,14,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                             MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                             Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                                    <TextBlock Text="Пол" Margin="0,14,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <ComboBox SelectedIndex="{Binding GenderIndex}"
                                              Height="50"
                                              Style="{StaticResource SortComboBoxStyle}">
                                        <ComboBoxItem Content="М" />
                                        <ComboBoxItem Content="Ж" />
                                    </ComboBox>

                                    <TextBlock Text="Дата рождения" Margin="0,14,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <DatePicker SelectedDate="{Binding BirthDate, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                                                Height="50"
                                                Style="{StaticResource MaskedDatePickerStyle}" />

                                    <TextBlock Text="Дата увольнения с последн. места раб." Margin="0,14,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <DatePicker SelectedDate="{Binding LastWorkDismissalDate, UpdateSourceTrigger=PropertyChanged}"
                                                Height="50"
                                                Style="{StaticResource MaskedDatePickerStyle}" />
                                </StackPanel>


                                <Grid Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0">
                                        <TextBlock Text="Место рождения" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                                 MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding BirthPlace, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,14,0,0">
                                        <TextBlock Text="Квалификация по диплому" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                                 MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding DiplomaQualification, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>



                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,14,0,0">
                                        <TextBlock Text="Член профсоюза" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <ToggleButton IsChecked="{Binding IsUnionMember}"
                                                      
                                                      Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                                      HorizontalAlignment="Left" 
                                                      Margin="0,14,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,14,0,0">
                                        <TextBlock Text="Категория" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                                 MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="5" Margin="0,14,0,0">
                                        <TextBlock Text="Домашний телефон" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                                 Height="50"
                                                 Text="{Binding HomePhone, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="5">
                                        <TextBlock Text="Дополнительные сведения" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                                 MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding AdditionalInfo, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,14,0,0">
                                        <TextBlock Text="Специальность по диплому" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                                 MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding DiplomaSpecialty, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2" >
                                        <TextBlock Text="Адрес" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                                 MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding Address, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,14,0,0">
                                        <TextBlock Text="Основная профессия" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                                 MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding MainProfession, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,14,0,0">
                                        <TextBlock Text="Телефон" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"

                                                 Height="50"
                                                 Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                                    </StackPanel>


                                    <StackPanel Grid.Row="2" Grid.Column="5" Margin="0,14,0,0">
                                        <TextBlock Text="Дата трудоустройства" 
               Margin="0,0,0,6" 
               Foreground="{StaticResource TextSecondaryBrush}" />
                                        <DatePicker SelectedDate="{Binding HireDate, UpdateSourceTrigger=PropertyChanged}"
                Height="50"
                Style="{StaticResource MaskedDatePickerStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,14,0,0">
                                        <TextBlock Text="Текущая должность" 
                                                   Margin="0,0,0,6" 
               Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
             MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
             Text="{Binding CurrentPosition, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Grid.Column="5" Margin="0,14,0,0">
                                        <TextBlock Text="Стаж работы по специальности" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
             Height="50"
             Text="{Binding SpecialtyExperienceYears, UpdateSourceTrigger=PropertyChanged}">
                                            <i:Interaction.Behaviors>
                                                <behaviors:NumericOnlyBehavior />
                                            </i:Interaction.Behaviors>
                                        </TextBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,14,0,0">
                                        <TextBlock Text="Общий стаж работы" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                                 Height="50"
                                                 Text="{Binding TotalExperienceYears, UpdateSourceTrigger=PropertyChanged}">
                                            <i:Interaction.Behaviors>
                                                <behaviors:NumericOnlyBehavior />
                                            </i:Interaction.Behaviors>
                                        </TextBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="5" Margin="0,14,0,0">
                                        <TextBlock Text="Срок действия контракта" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <DatePicker SelectedDate="{Binding ContractEndDate, UpdateSourceTrigger=PropertyChanged}"
                                                    Height="50"
                                                    Style="{StaticResource MaskedDatePickerStyle}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="5" Grid.Column="5" Margin="0,14,0,0">
                                        <TextBlock Text="Последнее место работы" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                Text="{Binding LastWorkPlace, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,14,0,0">
                                        <TextBlock Text="Должность на последн. месте раб." Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                                 MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding LastWorkPosition, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="5" Grid.Column="2" Margin="0,14,0,0">
                                        <TextBlock Text="Причина увольн. с последн. места раб." Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                                 MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                                 Text="{Binding LastWorkDismissalReason, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Паспорт">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPassportSectionPartiallyFilled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentYellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPassportSectionFullyFilled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="32,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="Серия паспорта" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                             MinHeight="50"
                                             Height="Auto"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding PassportSeries, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="Номер паспорта" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                             MinHeight="50"
                                             Height="Auto"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding PassportNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,14,0,0">
                                    <TextBlock Text="Идентификационный номер" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                             MinHeight="50"
                                             Height="Auto"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding IdentificationNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,14,0,0">
                                    <TextBlock Text="Кем выдан паспорт" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                             MinHeight="50"
                                             Height="Auto"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             Text="{Binding IssuedBy, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                                </StackPanel>

                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,14,0,0">
                                    <TextBlock Text="Дата выдачи паспорта" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <DatePicker SelectedDate="{Binding IssueDate, UpdateSourceTrigger=PropertyChanged}"
                                                Height="50"
                                                Style="{StaticResource MaskedDatePickerStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,14,0,0">
                                    <TextBlock Text="Паспорт действителен до" Margin="0,0,0,6" Foreground="{StaticResource TextSecondaryBrush}" />
                                    <DatePicker SelectedDate="{Binding PassportExpiryDate, UpdateSourceTrigger=PropertyChanged}"
                                                Height="50"
                                                Style="{StaticResource MaskedDatePickerStyle}" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Образование">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEducationSectionPartiallyFilled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentYellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsEducationSectionFullyFilled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </TabItem.Header>

                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="16">
                                <Button Content="Добавить запись об образовании"
                    Height="40"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,12"
                    Command="{Binding AddEducationCommand}"
                    Background="{StaticResource AccentGreenBrush}"
                    Foreground="White"
                    Padding="14,8"
                    Style="{StaticResource MaterialDesignRaisedButton}" />

                                <ItemsControl ItemsSource="{Binding EducationItems}" 
              HorizontalContentAlignment="Stretch">

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Border Padding="12"
                        Background="{StaticResource AppBackgroundBrush}"
                        CornerRadius="8"
                        MinWidth="850">

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="1.6*" />
                                                            <ColumnDefinition Width="1.3*" />
                                                            <ColumnDefinition Width="1.3*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>

                                                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,16">
                                                            <TextBlock Text="Уровень образования" 
                                       Margin="0,0,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                            <ComboBox Style="{StaticResource SortComboBoxStyle}"
                                      Height="50"
                                      ItemsSource="{Binding DataContext.EducationLevels, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding EducationLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberPath="Name"
                                      IsEditable="True"
                                      Text="{Binding CustomEducationLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,16">
                                                            <TextBlock Text="Учебное заведение" 
                                       Margin="0,0,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                            <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                     MinHeight="50"
                                     Height="Auto"
                                     TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                     Text="{Binding InstitutionName}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,16">
                                                            <TextBlock Text="Специальность" 
                                       Margin="0,0,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                            <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                     MinHeight="50"
                                     Height="Auto"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding Specialty}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                                            <TextBlock Text="Квалификация" 
                                       Margin="0,0,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                            <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                     MinHeight="50"
                                     Height="Auto"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding Qualification}" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,8,0">
                                                            <TextBlock Text="Дата окончания" 
                                       Margin="0,0,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                            <DatePicker SelectedDate="{Binding GraduationDate, UpdateSourceTrigger=PropertyChanged}"
                                        Style="{StaticResource MaskedDatePickerStyle}" 
                                        Height="50" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,8,0">
                                                            <TextBlock Text="Вид обучения" 
                                       Margin="0,0,0,4"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                            <TextBox Style="{StaticResource SearchTextBoxStyle}"
                                     MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                     Text="{Binding StudyType}" />
                                                        </StackPanel>

                                                        <Button Grid.Row="0" Grid.RowSpan="2"
                                Grid.Column="3"
                                Content="Удалить"
                                VerticalAlignment="Center"
                                Margin="15,0,5,0"
                                Style="{StaticResource LinkButtonStyle}"
                                Foreground="{StaticResource AccentRedBrush}"
                                Command="{Binding DataContext.RemoveEducationCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}" />
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Воинский учет">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMilitarySectionPartiallyFilled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentYellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMilitarySectionFullyFilled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="32,16">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
