                                                    <StackPanel Grid.Column="2" Margin="0,0,8,0" >
                                                        <TextBlock Text="Дней" Margin="18,0,0,20" Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBlock Text="{Binding DaysCountText, TargetNullValue='-'}"
                                               Height="50" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                                        <TextBlock Text="Дата свидетельства" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <DatePicker SelectedDate="{Binding CertificateDate, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource MaskedDatePickerStyle}" Height="50" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="5" Margin="0,0,8,0">
                                                        <TextBlock Text="Номер свидетельства" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBox Style="{StaticResource SearchTextBoxStyle}" MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                             Text="{Binding CertificateNumber, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="6" VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <Button Content="Удалить"
                                            Style="{StaticResource LinkButtonStyle}"
                                            Foreground="{StaticResource AccentRedBrush}"
                                            Command="{Binding DataContext.RemoveQualificationUpgradeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Переподготовка">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRetrainingSectionPartiallyFilled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentYellowBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRetrainingSectionFullyFilled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,12">
                                    <Button Content="Добавить запись о переподготовке"
                        Height="40"
                        Command="{Binding AddRetrainingCommand}"
                        Background="{StaticResource AccentGreenBrush}"
                        Foreground="White"
                        Padding="14,8"
                        Style="{StaticResource MaterialDesignRaisedButton}" />
                                </StackPanel>

                                <ItemsControl ItemsSource="{Binding RetrainingItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,10" Padding="12" Background="{StaticResource AppBackgroundBrush}" CornerRadius="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="1.4*" />
                                                        <ColumnDefinition Width="1.4*" />
                                                        <ColumnDefinition Width="0.7*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="1.4*" />
                                                        <ColumnDefinition Width="2*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                        <TextBlock Text="Дата начала" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <DatePicker SelectedDate="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource MaskedDatePickerStyle}" Height="50" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                                        <TextBlock Text="Специальность" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBox Style="{StaticResource SearchTextBoxStyle}" MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                             Text="{Binding Specialty, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                                        <TextBlock Text="Дата окончания" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <DatePicker SelectedDate="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}"
            Style="{StaticResource MaskedDatePickerStyle}" 
            Height="50" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" Margin="0,0,8,0" >
                                                        <TextBlock Text="Дней" Margin="18,0,0,20" Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBlock Text="{Binding DaysCountText, TargetNullValue='-'}"
Height="50" VerticalAlignment="Center" HorizontalAlignment="Center" 
Foreground="{StaticResource TextPrimaryBrush}" />
                                                    </StackPanel>




                                                    <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                                        <TextBlock Text="Дата диплома" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <DatePicker SelectedDate="{Binding DiplomaDate, UpdateSourceTrigger=PropertyChanged}"
                                                Style="{StaticResource MaskedDatePickerStyle}" Height="50" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="5" Margin="0,0,8,0">
                                                        <TextBlock Text="Номер диплома" Margin="0,0,0,4" Foreground="{StaticResource TextSecondaryBrush}" />
                                                        <TextBox Style="{StaticResource SearchTextBoxStyle}" MinHeight="50"
Height="Auto"
TextWrapping="Wrap"
AcceptsReturn="True"
VerticalScrollBarVisibility="Auto"
                                             Text="{Binding DiplomaNumber, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="6" VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <Button Content="Удалить"
                                            Style="{StaticResource LinkButtonStyle}"
                                            Foreground="{StaticResource AccentRedBrush}"
                                            Command="{Binding DataContext.RemoveRetrainingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="18,0,18,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Height="40"
                    Content="Сохранить и выйти"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding HasErrors, Converter={StaticResource InverseBool}}"
                    Background="{StaticResource AccentGreenBrush}"
                    Foreground="White"
                    Padding="24,10"
                    MinWidth="180"
                    MinHeight="40"
                    BorderThickness="0"
                    Style="{StaticResource MaterialDesignRaisedButton}" />
        </Grid>
    </Grid>
</UserControl>