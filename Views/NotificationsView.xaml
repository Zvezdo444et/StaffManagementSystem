<UserControl x:Class="Inspector.Views.NotificationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:Inspector.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,-10,0,20">
                <materialDesign:PackIcon Margin="0,4,0,0" Kind="BellRingOutline" Width="32" Height="32" Foreground="{StaticResource AccentGreenBrush}"/>
                <TextBlock Text="Уведомления" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource AccentGreenBrush}" VerticalAlignment="Center" Margin="16,0,0,0"/>
                <Button Content="Обновить" Command="{Binding RefreshCommand}" Margin="15,0,0,0" Style="{StaticResource MaterialDesignRaisedButton}" Background="{StaticResource AccentGreenBrush}" Foreground="White" Height="40" Width="140"/>
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="{StaticResource BorderLightBrush}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Notifications}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F9FA" CornerRadius="10" Margin="12,8" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:PackIcon Grid.Column="0" Kind="AlertCircle" Width="28" Height="28" Foreground="{StaticResource AccentGreenBrush}" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="15" Foreground="{StaticResource AccentGreenBrush}"/>
                                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Margin="0,4,0,0" FontSize="14"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Скрыть" Command="{Binding DataContext.DismissCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource MaterialDesignOutlinedButton}" Foreground="{StaticResource AccentRedBrush}" Height="36" Width="100" Margin="20,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <TextBlock Grid.Row="1" 
                       Text="Нет уведомлений" 
                       FontSize="18" 
                       Foreground="{StaticResource TextSecondaryBrush}" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       Visibility="{Binding HasNoNotifications, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </Grid>
    </Grid>
</UserControl>