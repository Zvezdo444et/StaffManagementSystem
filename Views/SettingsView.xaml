<UserControl x:Class="Inspector.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:helpers="clr-namespace:Inspector.Services"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1100">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="0,0,10,0">

        <Grid Margin="30,0,30,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Настройки"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,10"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="30" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Background="White"
                        CornerRadius="12"
                        Padding="20"
                        BorderBrush="{StaticResource BorderLightBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Виды родства"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                  />

                        <ListBox ItemsSource="{Binding RelationTypes}"
                                 Margin="0,0,0,20"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 MaxHeight="380"
                                 Height="180">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA"
                                            CornerRadius="8"
                                            Padding="8,2"
                                            BorderBrush="{StaticResource BorderLightBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       FontWeight="Medium"/>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    Width="32"
                                                    Height="32"
                                                    HorizontalAlignment="Right"
                                                    Foreground="{StaticResource AccentRedBrush}"
                                                    Command="{Binding DataContext.DeleteRelationTypeCommand, 
                                                                      RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding NewRelationTypeName, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Новый вид родства"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            <Button Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Content="Добавить"
                                    Command="{Binding AddRelationTypeCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Height="42"
                                    MinWidth="120"
                                    Background="{StaticResource AccentGreenBrush}"
                                    Foreground="White"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="White"
                        CornerRadius="12"
                        Padding="20"
                        BorderBrush="{StaticResource BorderLightBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Уровни образования"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                  />

                        <ListBox ItemsSource="{Binding EducationLevels}"
                                 Margin="0,0,0,20"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 MaxHeight="380"
                                 Height="180">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA"
                                            CornerRadius="8"
                                            Padding="8,2"
                                            BorderBrush="{StaticResource BorderLightBrush}"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Name}"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"
                                                       FontWeight="Medium"/>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource MaterialDesignIconButton}"
                                                    Width="32"
                                                    Height="32"
                                                    HorizontalAlignment="Right"
                                                    Foreground="{StaticResource AccentRedBrush}"
                                                    Command="{Binding DataContext.DeleteEducationLevelCommand, 
                                                                      RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="DeleteOutline" Width="18" Height="18"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding NewEducationLevelName, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Новый уровень образования"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            <Button Grid.Column="1"
                                    Margin="12,0,0,0"
                                    Content="Добавить"
                                    Command="{Binding AddEducationLevelCommand}"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Height="42"
                                    MinWidth="120"
                                    Background="{StaticResource AccentGreenBrush}"
                                    Foreground="White"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
        Background="White"
        CornerRadius="12"
        Padding="10"
        Margin="0,10,0,0"
        BorderBrush="{StaticResource BorderLightBrush}"
        BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Смена пароля"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Margin="0,0,0,6"/>

                    <StackPanel Margin="0,0,0,20">
                        <PasswordBox x:Name="OldPasswordBox"
                         Margin="0,3"
                         Height="50"
                         materialDesign:HintAssist.Hint="Старый пароль"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         helpers:PasswordHelper.Attach="True"
                         helpers:PasswordHelper.BoundPassword="{Binding OldPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <PasswordBox x:Name="NewPasswordBox"
                         Margin="0,3"
                         Height="50"
                         materialDesign:HintAssist.Hint="Новый пароль"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         helpers:PasswordHelper.Attach="True"
                         helpers:PasswordHelper.BoundPassword="{Binding NewPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <PasswordBox x:Name="ConfirmPasswordBox"
                         Height="50"
                                     Margin="0,3"
                         materialDesign:HintAssist.Hint="Повторите новый пароль"
                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                         helpers:PasswordHelper.Attach="True"
                         helpers:PasswordHelper.BoundPassword="{Binding ConfirmPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <Button Content="Сменить пароль"
                Command="{Binding ChangePasswordCommand}"
                HorizontalAlignment="Left"
                Height="42"
                MinWidth="170"
                Background="{StaticResource AccentGreenBrush}"
                Foreground="White"
                Style="{StaticResource MaterialDesignRaisedButton}"/>

                    <TextBlock Text="{Binding PasswordChangeMessage}"
                   HorizontalAlignment="Center"
                   Foreground="{Binding PasswordChangeMessageColor}"
                   FontWeight="Medium"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>