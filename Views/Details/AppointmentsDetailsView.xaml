<UserControl x:Class="Inspector.Views.Details.AppointmentsDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="24,20,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="{Binding Employee.FullName, StringFormat='Назначения и перемещения {0}'}"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource AccentGreenBrush}"
                       VerticalAlignment="Center" HorizontalAlignment="Left" />
            <Button Grid.Column="1"
                    Content="Редактировать"
                    Height="42" Width="155"
                    Command="{Binding EditCommand}"
                    Background="{StaticResource AccentGreenBrush}"
                    Foreground="White"
                    Padding="16,8" FontSize="15" FontWeight="Medium"
                    Style="{StaticResource MaterialDesignRaisedButton}" />
            <Button Grid.Column="2"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Height="42" Width="60" Margin="10,0,0,0"
                    Command="{Binding CloseCommand}"
                    ToolTip="Закрыть"
                    Background="Transparent"
                    Foreground="{StaticResource AccentGreenBrush}">
                <materialDesign:PackIcon Kind="Close" Width="28" Height="28"
                                         Foreground="{StaticResource AccentGreenBrush}" />
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1" Margin="24,12,24,24"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="0,0,24,0">
         
                <ItemsControl ItemsSource="{Binding Employee.AppointmentTransfers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#33EA00FF" 
                                    CornerRadius="12" 
                                    Margin="0,6" 
                                    Padding="16">
                                <StackPanel>
                                    <TextBlock Text="{Binding Date, StringFormat='Дата назначения: dd.MM.yyyy'}"
                                               Foreground="Black" FontWeight="Medium" />
                                    <TextBlock Text="{Binding Position, StringFormat='Должность: {0}'}"
                                               Foreground="Black" FontWeight="Medium" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding ContractType, StringFormat='Вид договора: {0}'}"
                                               Foreground="Black" FontWeight="Medium" />
                                    <TextBlock Text="{Binding ContractTerm, StringFormat='Период договора: {0}'}"
                                               Foreground="Black" FontWeight="Medium" />
                                    <TextBlock Text="{Binding BasisDocumentName, StringFormat='Документ-основание: {0}'}"
                                               Foreground="Black" FontWeight="Medium" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding BasisDocumentNumber, StringFormat='Номер основания: {0}'}"
                                               Foreground="Black" FontWeight="Medium" />
                                    <TextBlock Text="{Binding DocumentDate, StringFormat='Дата документа: dd.MM.yyyy'}"
                                               Foreground="Black" FontWeight="Medium" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>